# Stripe Secret Key from your Stripe Dashboard (Developers -> API Keys)
# Starts with sk_test_... (for testing) or sk_live_... (for production)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# The URLs Stripe Checkout redirects to after a successful or canceled payment
SUCCESS_URL=https://vazerk.com/success.html
CANCEL_URL=https://vazerk.com/cancel.html

# Port for the Express server to listen on
PORT=3000
